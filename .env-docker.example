# ===============================
# Core
# ===============================
APP_NAME=YouTube Daily Comments Intelligence
APP_TIMEZONE=Europe/Berlin
LOG_LEVEL=INFO
DRY_RUN=false
DRY_RUN_FIXTURE_PATH=tests/fixtures/mock_youtube.json

# ===============================
# Pipeline Mode
# ===============================
EMBEDDING_MODE=local

# ===============================
# YouTube Input
# ===============================
YOUTUBE_API_KEY=
YOUTUBE_PLAYLIST_ID=
YOUTUBE_TITLE_REGEX=
YOUTUBE_EXCLUDE_SHORTS=true
YOUTUBE_SHORT_THRESHOLD_SECONDS=120
YOUTUBE_INCLUDE_REPLIES=false
YOUTUBE_REQUEST_TIMEOUT_SEC=20
YOUTUBE_RATE_LIMIT_RPS=5
YOUTUBE_MAX_PAGES=20
MAX_COMMENTS_PER_VIDEO=1500
YOUTUBE_MIX_RELEVANCE_COMMENTS=true
YOUTUBE_RELEVANCE_COMMENTS_SHARE=0.35

# ===============================
# OpenAI
# ===============================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REQUIRE_OFFICIAL_ENDPOINT=true
# Available models: gpt-4o-mini (default), gpt-4o, gpt-5-mini, gpt-5.2
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_USD_PER_RUN=0
OPENAI_HARD_BUDGET_ENFORCED=false
OPENAI_MAX_OUTPUT_TOKENS=4096
OPENAI_ENABLE_POLISH_CALL=false
OPENAI_MAX_CALLS_PER_RUN=999999
OPENAI_CALLS_RESERVED_FOR_LABELING=0
OPENAI_MAX_MODERATION_CALLS_PER_RUN=999999
OPENAI_MAX_POSITION_NAMING_CALLS_PER_RUN=999999

# ===============================
# Embeddings and Author
# ===============================
LOCAL_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_INSTRUCTION_MODE=off
LOCAL_EMBEDDING_DEVICE=auto
LOCAL_EMBEDDING_BATCH_SIZE=32
LOCAL_EMBEDDING_MAX_SEQ_LENGTH=0
LOCAL_EMBEDDING_LOW_VRAM_MODE=false
LOCAL_EMBEDDING_OOM_FALLBACK_TO_CPU=true
AUTHOR_NAME=

# ===============================
# YouTube Ban Integration
# ===============================
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REFRESH_TOKEN=
YOUTUBE_BAN_TOKEN=
AUTO_BAN_THRESHOLD=0.92
MANUAL_REVIEW_THRESHOLD=0.5

# ===============================
# Comment Preprocessing
# ===============================
PREPROCESSING_FILTER_ENABLED=true
COMMENT_MIN_WORDS=3
COMMENT_MAX_CHARS=2000
COMMENT_WEIGHT_MAX=5.0
PREPROCESSING_LOW_SIGNAL_FILTER_ENABLED=true
PREPROCESSING_LOW_SIGNAL_MIN_ALPHA_CHARS=5
PREPROCESSING_LOW_SIGNAL_MAX_SYMBOL_RATIO=0.45
PREPROCESSING_LOW_SIGNAL_MIN_LEXICAL_DIVERSITY=0.34

# ===============================
# Moderation
# ===============================
MODERATION_ENABLED=true
MODERATION_TOXICITY_POLICY=keep_flag
MODERATION_ENABLE_LLM_BORDERLINE=true
MODERATION_LLM_SCOPE=borderline
MODERATION_LLM_MAX_REVIEWS_PER_RUN=300
MODERATION_FLAGGED_WEIGHT_MULTIPLIER=0.85
MODERATION_PROFANITY_ONLY_MAX_WORDS=6
MODERATION_TOPIC_TOKEN_MIN_OVERLAP=1
MODERATION_BORDERLINE_MIN_SCORE=0.35
MODERATION_BORDERLINE_MAX_SCORE=0.55
MODERATION_LOG_INCLUDE_REASON_BREAKDOWN=true
MODERATION_LOG_INCLUDE_SAMPLES=false
MODERATION_LOG_SAMPLE_SIZE=3

# ===============================
# Top-Level Clustering
# ===============================
CLUSTER_MIN_SIZE=3
CLUSTER_MIN_SAMPLES=1
CLUSTER_MAX_COUNT=10
CLUSTER_REDUCTION_ENABLED=false
CLUSTER_REDUCTION_TARGET_DIM=32
CLUSTER_REDUCTION_MIN_COMMENTS=80
CLUSTER_ACCEPT_NOISE_RATIO=0.98
CLUSTER_SMALLSET_ACCEPT_NOISE_RATIO=0.995
CLUSTER_SOFT_ASSIGNMENT_ENABLED=false
CLUSTER_SOFT_ASSIGNMENT_MIN_SIMILARITY=0.42
CLUSTER_AMBIGUITY_CONFIDENCE_THRESHOLD=0.58
CLUSTER_AMBIGUITY_MARGIN_THRESHOLD=0.08
CLUSTER_ASSIGNMENT_NOTE_LIMIT=3
CLUSTER_KMEANS_FALLBACK_ENABLED=true
CLUSTER_KMEANS_FALLBACK_MIN_SIZE=24
CLUSTER_NOISE_SPLIT_ENABLED=true
CLUSTER_NOISE_SPLIT_MIN_SIZE=28
CLUSTER_NOISE_SPLIT_MIN_SHARE_PCT=18
CLUSTER_NOISE_SPLIT_TARGET_GROUP_SIZE=14
CLUSTER_NOISE_SPLIT_MAX_GROUPS=10
CLUSTER_NOISE_SPLIT_MIN_SILHOUETTE_SMALL=-0.02
CLUSTER_NOISE_SPLIT_MIN_SILHOUETTE_LARGE=0.00
CLUSTER_NOISE_SPLIT_MIN_AVG_COHERENCE=0.10
CLUSTER_NOISE_SPLIT_MIN_GROUP_COHERENCE=0.05
CLUSTER_LARGE_SPLIT_ENABLED=true
CLUSTER_LARGE_SPLIT_MIN_SHARE_PCT=25.0
CLUSTER_LARGE_SPLIT_MAX_SUBGROUPS=4
CLUSTER_MERGE_ENABLED=true
CLUSTER_MERGE_SIMILARITY_THRESHOLD=0.88
CLUSTER_MERGE_KEYWORD_JACCARD_MIN=0.2
CLUSTER_MERGE_MAX_ROUNDS=3

# ===============================
# Topic Postprocessing
# ===============================
TOPIC_MERGE_ENABLED=false
TOPIC_MERGE_SIMILARITY_THRESHOLD=0.88
TOPIC_MERGE_LABEL_JACCARD_MIN=0.24
TOPIC_MERGE_LABEL_SUBSET_MIN_TOKENS=2
TOPIC_CROSS_DEDUPE_ENABLED=true
TOPIC_CROSS_DEDUPE_SIMILARITY_THRESHOLD=0.9
TOPIC_UNCERTAIN_MIN_COMMENTS=1
TOPIC_UNCERTAIN_SUPPORT_MIN=0.14
TOPIC_COHERENCE_MIN=0.38
TOPIC_MIN_WEIGHTED_SHARE_FOR_LOW_COHERENCE=7.0
REPORT_TOP_K_TOPICS=6
REPORT_ACTIONS_LIMIT=5
REPORT_QUOTES_PER_TOPIC=8
REPORT_TOTAL_QUOTES_LIMIT=24
MAX_REPRESENTATIVES_PER_CLUSTER=4

# ===============================
# Transcript / Episode Context (compatibility fields)
# ===============================
ENABLE_TRANSCRIPT_CONTEXT=true
TRANSCRIPT_MODEL=medium
TRANSCRIPT_DEVICE=auto
TRANSCRIPT_LANGUAGE=ru
TRANSCRIPT_BEAM_SIZE=5
TRANSCRIPT_VAD_FILTER=true
TRANSCRIPT_MAX_CHARS=22000
TRANSCRIPT_TOPIC_COUNT=8
TRANSCRIPT_TOPIC_MATCH_MIN_SIMILARITY=0.5
TRANSCRIPT_COMPUTE_TYPE_CUDA=float16
TRANSCRIPT_COMPUTE_TYPE_CPU=int8
TRANSCRIPT_KEEP_AUDIO=false

# ===============================
# Position Subclustering
# ===============================
POSITION_LLM_SAMPLE_MIN=80
POSITION_LLM_SAMPLE_MAX=200
POSITION_LLM_SAMPLE_MIN_OPENAI=12
POSITION_LLM_SAMPLE_MAX_OPENAI=24
POSITION_LLM_COMMENT_CHAR_CAP=220
POSITION_LLM_PAYLOAD_CHAR_BUDGET=5000
POSITION_TITLE_RETRY_COUNT=1
POSITION_LLM_NAMING_MIN_GROUP_SIZE=3
POSITION_SUBCLUSTER_MAX_K=0
POSITION_SUBCLUSTER_MIN_GROUP_SIZE=2
POSITION_SUBCLUSTER_MIN_GROUP_SHARE_PCT=3.0
POSITION_SUBCLUSTER_HDBSCAN_SCALE=0.75
POSITION_SUBCLUSTER_HDBSCAN_MAX_CLUSTER_SIZE=8
POSITION_ASSIGNMENT_MIN_SIMILARITY=0.40
POSITION_ASSIGNMENT_BORDERLINE_SIMILARITY=0.48
POSITION_ASSIGNMENT_MIN_MARGIN=0.06

# ===============================
# Quality / Diagnostics
# ===============================
QUALITY_WATCHDOG_UNDETERMINED_SHARE_PCT=35
QUALITY_WATCHDOG_FALLBACK_TITLE_RATE_PCT=40
CLUSTER_DIAGNOSTICS_ENABLED=true
TREND_SIMILARITY_THRESHOLD=0.72

# ===============================
# Paths
# ===============================
CACHE_DIR=data/cache
DATA_DIR=data
RAW_DIR=data/raw
REPORTS_DIR=data/reports

# ===============================
# Infrastructure (Docker networking)
# ===============================
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/youtube_intel
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
SCHEDULE_DAILY_AT=06:30
ENABLE_SCHEDULED_RUNS=false
INCLUDE_REPLIES=false
